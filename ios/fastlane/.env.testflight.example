# Auth mode A: App Store Connect API Key (recommended)
# APP_STORE_CONNECT_API_KEY_ID=YOUR_KEY_ID
# APP_STORE_CONNECT_API_ISSUER_ID=YOUR_ISSUER_ID
# APP_STORE_CONNECT_API_KEY_PATH=/absolute/path/to/AuthKey_XXXXXX.p8

# Auth mode B: Apple ID (use this if you can't access App Store Connect API)
# APP_STORE_CONNECT_USERNAME=you@example.com
# FASTLANE_APPLE_APPLICATION_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx
# APP_STORE_CONNECT_APPLE_ID=1234567890

IOS_APPLE_TEAM_ID=J6PH9SW96A
IOS_BUNDLE_ID=com.yuxiaoyi.activehealthlbp
IOS_SCHEME=ActiveHealth
IOS_WORKSPACE=ActiveHealth.xcworkspace
IOS_XCODEPROJ=ActiveHealth.xcodeproj
IOS_BUILD_OUTPUT_DIR=build

# Optional
# IOS_BUILD_NUMBER=2
# TESTFLIGHT_CHANGELOG=本次更新内容
# IOS_SKIP_PODS=1
# IOS_UPLOAD_ONLY=1
