default_platform(:ios)

def require_env!(key)
  value = ENV[key]
  UI.user_error!("Missing ENV[#{key}]. Check ios/fastlane/.env.testflight.") if value.to_s.empty?
  value
end

def present_env?(key)
  !ENV[key].to_s.empty?
end

platform :ios do
  desc "Build and upload ActiveHealth to TestFlight"
  lane :beta do |options|
    project_root = File.expand_path("..", __dir__)
    workspace = options[:workspace] || ENV.fetch("IOS_WORKSPACE", "ActiveHealth.xcworkspace")
    scheme = options[:scheme] || ENV.fetch("IOS_SCHEME", "ActiveHealth")
    xcodeproj = options[:xcodeproj] || ENV.fetch("IOS_XCODEPROJ", "ActiveHealth.xcodeproj")
    output_dir = File.expand_path(
      ENV.fetch("IOS_BUILD_OUTPUT_DIR", "build"),
      project_root
    )
    ipa_path = File.join(output_dir, "#{scheme}.ipa")
    build_number = options[:build_number] || ENV["IOS_BUILD_NUMBER"]
    upload_only = options[:upload_only].to_s == "true" || ENV["IOS_UPLOAD_ONLY"] == "1"

    use_api_key_auth = %w[
      APP_STORE_CONNECT_API_KEY_ID
      APP_STORE_CONNECT_API_ISSUER_ID
      APP_STORE_CONNECT_API_KEY_PATH
    ].all? { |key| present_env?(key) }

    api_key = nil
    username = nil
    app_store_connect_apple_id = nil

    if use_api_key_auth
      UI.message("Using App Store Connect API key authentication.")
      api_key = app_store_connect_api_key(
        key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
        issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
        key_filepath: ENV["APP_STORE_CONNECT_API_KEY_PATH"],
        in_house: false
      )
    else
      UI.message("Using Apple ID authentication (no API key).")
      username = require_env!("APP_STORE_CONNECT_USERNAME")
      require_env!("FASTLANE_APPLE_APPLICATION_SPECIFIC_PASSWORD")
      app_store_connect_apple_id = require_env!("APP_STORE_CONNECT_APPLE_ID")
    end

    if upload_only
      UI.user_error!("Missing IPA at #{ipa_path}. Disable IOS_UPLOAD_ONLY or build once first.") unless File.exist?(ipa_path)
    else
      unless ENV["IOS_SKIP_PODS"] == "1"
        cocoapods(
          podfile: "Podfile",
          clean_install: false
        )
      end

      if build_number.to_s.empty?
        increment_build_number(xcodeproj: xcodeproj)
      else
        increment_build_number(
          xcodeproj: xcodeproj,
          build_number: build_number
        )
      end

      build_app(
        workspace: workspace,
        scheme: scheme,
        configuration: "Release",
        clean: true,
        export_method: "app-store",
        output_directory: output_dir,
        output_name: "#{scheme}.ipa",
        include_symbols: true,
        include_bitcode: false,
        xcargs: "-allowProvisioningUpdates"
      )
    end

    upload_options = {
      ipa: ipa_path,
      skip_waiting_for_build_processing: true,
      skip_submission: true,
      distribute_external: false,
      changelog: options[:changelog] || ENV["TESTFLIGHT_CHANGELOG"]
    }

    if api_key
      upload_options[:api_key] = api_key
    else
      upload_options[:username] = username
      upload_options[:apple_id] = app_store_connect_apple_id
    end

    upload_to_testflight(**upload_options)
  end
end
